# LLM API (DeepSeek / Qwen / OpenAI — OpenAI-compatible)
# Get your key from: https://platform.deepseek.com/api_keys
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Database
DB_PATH=./data/speakmate.db

# Whisper (reserved for future speech recognition)
WHISPER_MODEL=base

# Server
HOST=0.0.0.0
PORT=8000